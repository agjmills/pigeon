{
  "name": "pigeon",
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply pigeon --local",
    "db:migrate:remote": "wrangler d1 migrations apply pigeon --remote",
    "db:create": "wrangler d1 create pigeon",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.16",
    "postal-mime": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260504.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.87.0"
  }
}
